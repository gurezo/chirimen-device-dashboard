{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@chirimen-device-dashboard/shared-types": [
        "libs/shared-types/src/index.ts"
      ],
      "@chirimen-device-dashboard/libs-data-access": [
        "libs/devices/data-access/src/index.ts"
      ],
      "@chirimen-device-dashboard/libs-state": [
        "libs/devices/state/src/index.ts"
      ],
      "@chirimen-device-dashboard/libs-feature-list": [
        "libs/devices/feature-list/src/index.ts"
      ],
      "@chirimen-device-dashboard/api/*": [
        "apps/api/src/*"
      ],
      "@chirimen-device-dashboard/libs-card-list": [
        "libs/devices/card-list/src/index.ts"
      ],
      "@chirimen-device-dashboard/libs-device-detail": [
        "libs/devices/device-detail/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
